# Auto-detect text files — force LF so cross-platform CI comparisons are stable
*.md text=auto eol=lf
*.py text=auto eol=lf
*.sh text=auto eol=lf
*.ps1 text=auto eol=lf
*.toml text=auto eol=lf
*.yaml text=auto eol=lf
*.json text=auto eol=lf
*.yml text=auto eol=lf
*.txt text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
