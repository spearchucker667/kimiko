{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kimi.dev/schemas/v1.0.0/config-schema.json",
  "title": "Kimi CLI Config Schema",
  "description": "JSON Schema for validating Kimi CLI config.toml files",
  "type": "object",
  "required": ["default_model", "providers", "loop_control", "background"],
  "properties": {
    "default_model": { "type": "string", "minLength": 1 },
    "default_thinking": { "type": "boolean" },
    "default_yolo": { "type": "boolean" },
    "skip_afk_prompt_injection": { "type": "boolean" },
    "default_plan_mode": { "type": "boolean" },
    "default_editor": { "type": "string" },
    "theme": { "type": "string", "enum": ["dark", "light", "auto"] },
    "show_thinking_stream": { "type": "boolean" },
    "hooks": { "type": "array", "items": { "type": "string" } },
    "merge_all_available_skills": { "type": "boolean" },
    "extra_skill_dirs": { "type": "array", "items": { "type": "string" } },
    "telemetry": { "type": "boolean" },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["provider", "model", "max_context_size"],
        "properties": {
          "provider": { "type": "string", "minLength": 1 },
          "model": { "type": "string", "minLength": 1 },
          "max_context_size": { "type": "integer", "minimum": 1 },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["image_in", "thinking", "video_in", "audio_in", "file_out"]
            }
          },
          "display_name": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "base_url"],
        "properties": {
          "type": { "type": "string", "enum": ["kimi", "openai", "anthropic", "google", "local"] },
          "base_url": { "type": "string", "format": "uri" },
          "api_key": { "type": "string" },
          "oauth": {
            "type": "object",
            "required": ["storage", "key"],
            "properties": {
              "storage": { "type": "string", "enum": ["file", "keychain", "env"] },
              "key": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "loop_control": {
      "type": "object",
      "required": ["max_steps_per_turn", "max_retries_per_step"],
      "properties": {
        "max_steps_per_turn": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "max_retries_per_step": { "type": "integer", "minimum": 0, "maximum": 10 },
        "max_ralph_iterations": { "type": "integer", "minimum": 0 },
        "reserved_context_size": { "type": "integer", "minimum": 0 },
        "compaction_trigger_ratio": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "properties": {
        "max_running_tasks": { "type": "integer", "minimum": 1 },
        "read_max_bytes": { "type": "integer", "minimum": 1 },
        "notification_tail_lines": { "type": "integer", "minimum": 1 },
        "notification_tail_chars": { "type": "integer", "minimum": 1 },
        "wait_poll_interval_ms": { "type": "integer", "minimum": 1 },
        "worker_heartbeat_interval_ms": { "type": "integer", "minimum": 1 },
        "worker_stale_after_ms": { "type": "integer", "minimum": 1 },
        "kill_grace_period_ms": { "type": "integer", "minimum": 1 },
        "keep_alive_on_exit": { "type": "boolean" },
        "agent_task_timeout_s": { "type": "integer", "minimum": 1 },
        "print_wait_ceiling_s": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "notifications": {
      "type": "object",
      "properties": {
        "claim_stale_after_ms": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "services": {
      "type": "object",
      "properties": {
        "moonshot_search": {
          "type": "object",
          "properties": {
            "base_url": { "type": "string", "format": "uri" },
            "api_key": { "type": "string" },
            "oauth": {
              "type": "object",
              "properties": {
                "storage": { "type": "string" },
                "key": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "moonshot_fetch": {
          "type": "object",
          "properties": {
            "base_url": { "type": "string", "format": "uri" },
            "api_key": { "type": "string" },
            "oauth": {
              "type": "object",
              "properties": {
                "storage": { "type": "string" },
                "key": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "mcp": {
      "type": "object",
      "properties": {
        "client": {
          "type": "object",
          "properties": {
            "tool_call_timeout_ms": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
