{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kimi.dev/schemas/v1.0.0/credentials-schema.json",
  "title": "Kimi Credentials Schema",
  "description": "JSON Schema for validating Kimi CLI OAuth credential files",
  "type": "object",
  "required": ["access_token", "token_type"],
  "properties": {
    "access_token": {
      "type": "string",
      "minLength": 10,
      "description": "OAuth access token (must not be empty or trivial)"
    },
    "token_type": {
      "type": "string",
      "enum": ["Bearer", "bearer"],
      "description": "OAuth token type"
    },
    "expires_at": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Unix timestamp when the token expires"
    },
    "expires_in": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Seconds until the token expires"
    },
    "refresh_token": {
      "type": ["string", "null"],
      "description": "OAuth refresh token"
    },
    "scope": {
      "type": ["string", "null"],
      "description": "OAuth scope string"
    }
  },
  "additionalProperties": false
}
