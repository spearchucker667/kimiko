{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kimi.dev/schemas/v1.0.0/kimi-json-schema.json",
  "title": "Kimi JSON Registry Schema",
  "description": "JSON Schema for validating kimi.json work-directory registry",
  "type": "object",
  "required": ["work_dirs"],
  "properties": {
    "work_dirs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kaos"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Absolute path to the workspace"
          },
          "kaos": {
            "type": "string",
            "enum": ["local", "remote", "hybrid"],
            "description": "Execution mode for this workspace"
          },
          "last_session_id": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "UUID of the most recent session"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
